<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="900" viewBox="0 0 1200 900">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#f0f9f8"/>
      <stop offset="100%" stop-color="#e0f2f0"/>
    </linearGradient>
    <linearGradient id="wall" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="100%" stop-color="#f5fafa"/>
    </linearGradient>
    <linearGradient id="chair" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a8a7d"/>
      <stop offset="100%" stop-color="#0a6c5f"/>
    </linearGradient>
    <linearGradient id="light" x1="0.5" y1="0" x2="0.5" y2="1">
      <stop offset="0%" stop-color="#fff8e1" stop-opacity="0.9"/>
      <stop offset="100%" stop-color="#fff8e1" stop-opacity="0"/>
    </linearGradient>
    <radialGradient id="lampglow">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1200" height="900" fill="url(#bg)"/>
  <rect x="0" y="0" width="1200" height="600" fill="url(#wall)"/>
  <rect x="0" y="600" width="1200" height="300" fill="#e8f5f3" rx="0"/>
  <rect x="100" y="550" width="1000" height="350" rx="16" fill="#d4ece8"/>
  <rect x="120" y="570" width="960" height="310" rx="12" fill="#c4e4df"/>
  <ellipse cx="600" cy="520" rx="400" ry="60" fill="#b8dbd5" opacity="0.5"/>
  <rect x="350" y="350" width="500" height="220" rx="20" fill="url(#chair)"/>
  <rect x="370" y="370" width="460" height="180" rx="16" fill="#1a9a8a"/>
  <rect x="400" y="400" width="120" height="50" rx="8" fill="#157a6e"/>
  <rect x="550" y="400" width="120" height="50" rx="8" fill="#157a6e"/>
  <rect x="480" y="340" width="240" height="20" rx="10" fill="#0d5c52"/>
  <circle cx="490" cy="350" r="8" fill="#0d5c52"/>
  <circle cx="710" cy="350" r="8" fill="#0d5c52"/>
  <circle cx="600" cy="330" r="30" fill="url(#lampglow)"/>
  <ellipse cx="600" cy="320" rx="80" ry="8" fill="#0d5c52" opacity="0.3"/>
  <rect x="590" y="320" width="20" height="60" rx="4" fill="#a0c0bb"/>
  <ellipse cx="600" cy="380" rx="15" ry="4" fill="#0d5c52" opacity="0.2"/>
  <rect x="200" y="180" width="160" height="220" rx="8" fill="#ffffff" stroke="#d0e5e0" stroke-width="2"/>
  <line x1="280" y1="240" x2="280" y2="340" stroke="#0a7c6d" stroke-width="2" stroke-dasharray="4,4"/>
  <rect x="240" y="260" width="80" height="6" rx="3" fill="#0a7c6d" opacity="0.3"/>
  <rect x="240" y="280" width="60" height="6" rx="3" fill="#0a7c6d" opacity="0.2"/>
  <rect x="240" y="300" width="70" height="6" rx="3" fill="#0a7c6d" opacity="0.2"/>
  <rect x="200" y="420" width="160" height="8" rx="4" fill="#0a7c6d" opacity="0.3"/>
  <rect x="200" y="440" width="120" height="8" rx="4" fill="#0a7c6d" opacity="0.15"/>
  <rect x="840" y="200" width="200" height="140" rx="8" fill="#ffffff" stroke="#d0e5e0" stroke-width="2"/>
  <rect x="860" y="220" width="160" height="100" rx="4" fill="#e8f5f3"/>
  <circle cx="940" cy="270" r="30" fill="#d4ece8"/>
  <circle cx="940" cy="270" r="15" fill="#c0e0d8"/>
  <rect x="840" y="360" width="200" height="8" rx="4" fill="#0a7c6d" opacity="0.3"/>
  <rect x="840" y="380" width="160" height="8" rx="4" fill="#0a7c6d" opacity="0.15"/>
  <rect x="0" y="0" width="1200" height="4" fill="#0a7c6d"/>
  <rect x="0" y="0" width="90" height="600" rx="0" fill="#f5fafa"/>
  <rect x="1110" y="0" width="90" height="600" rx="0" fill="#f5fafa"/>
  <text x="600" y="870" text-anchor="middle" font-family="Georgia,serif" font-size="14" fill="#0a7c6d" opacity="0.5">Premium dental environment</text>
</svg>